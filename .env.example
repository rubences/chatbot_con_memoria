# Copia este archivo como .env y rellena tus valores reales.
# NUNCA subas el archivo .env al repositorio.

# Proveedor de inferencia: openai | huggingface
PROVEEDOR=huggingface

# Clave de acceso a la API de OpenAI (o proveedor compatible)
OPENAI_API_KEY=tu_clave_aqui

# Token de Hugging Face (https://huggingface.co/settings/tokens)
# Si PROVEEDOR=huggingface, se usará HF_API_KEY con prioridad.
HF_API_KEY=hf_tu_token_aqui

# Credenciales de LlamaCloud para ingesta RAG de documentos
LLAMA_CLOUD_API_KEY=llx_tu_token_aqui
LLAMA_CLOUD_TIER=agentic
LLAMA_CLOUD_VERSION=latest

# Deployment remoto de LlamaIndex Workflows
LLAMA_WORKFLOW_BASE_URL=https://api.cloud.llamaindex.ai/deployments/creaci-n-de-un-agente-experto-en-ia
LLAMA_WORKFLOW_NAME=my_workflow
LLAMA_WORKFLOW_EVENTO_MENSAJE=mensaje
LLAMA_WORKFLOW_EVENTO_ARCHIVO=file_id

# URL base para proveedor OpenAI-compatible.
# Hugging Face router: https://router.huggingface.co/v1
# Ollama local: http://localhost:11434/v1
OPENAI_BASE_URL=https://router.huggingface.co/v1

# Nombre del modelo a utilizar
MODELO=openai/gpt-oss-20b:fireworks-ai

# Temperatura de muestreo del modelo (0.0 = determinista, 2.0 = muy creativo)
TEMPERATURA=0.7

# Mensaje de sistema que define la personalidad del asistente
MENSAJE_SISTEMA=Eres un asistente experto en Python e IA, con un toque sarcástico pero siempre útil.

# Configuración de Django
DJANGO_SECRET_KEY=django-insecure-desarrollo-chatbot-con-memoria
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
